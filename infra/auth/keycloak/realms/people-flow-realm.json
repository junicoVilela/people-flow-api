{
  "realm": "people-flow",
  "enabled": true,
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "resetPasswordAllowed": true,
  "clients": [
    {
      "clientId": "people-flow-api",
      "secret": "peopleflow-secret-change-in-production",
      "protocol": "openid-connect",
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "attributes": { "oauth2.device.authorization.grant.enabled": "false" },
      "defaultClientScopes": ["web-origins", "roles", "profile", "email"],
      "protocolMappers": [
        {
          "name": "empresaId",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "empresaId",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "empresaId",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ],
  "roles": {
    "realm": [],
    "client": {
      "people-flow-api": [
        { "name": "admin", "description": "Administrador do sistema" },
        { "name": "colaborador:criar", "description": "Criar colaboradores" },
        { "name": "colaborador:ler", "description": "Visualizar colaboradores" },
        { "name": "colaborador:editar", "description": "Editar colaboradores e vínculos (contrato, documentos, etc.)" },
        { "name": "colaborador:deletar", "description": "Excluir colaboradores e documentos (soft delete)" },
        { "name": "colaborador:demitir", "description": "Registrar demissão" },
        { "name": "colaborador:aprovar", "description": "Aprovar cadastros e alterações" },
        { "name": "organizacao:criar", "description": "Criar estrutura organizacional" },
        { "name": "organizacao:ler", "description": "Consultar estrutura organizacional" },
        { "name": "organizacao:editar", "description": "Editar estrutura organizacional" },
        { "name": "organizacao:deletar", "description": "Soft delete na estrutura organizacional" },
        { "name": "nivel_hierarquico:criar", "description": "Criar níveis hierárquicos" },
        { "name": "nivel_hierarquico:ler", "description": "Consultar níveis hierárquicos" },
        { "name": "nivel_hierarquico:editar", "description": "Editar níveis hierárquicos" },
        { "name": "nivel_hierarquico:deletar", "description": "Excluir níveis hierárquicos" }
      ]
    }
  },
